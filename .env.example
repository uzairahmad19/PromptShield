# ============================================================
#  PromptShield Environment Variables
#  Copy this to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# Ollama runs locally — no API key needed.
# Just make sure `ollama serve` is running.
OLLAMA_BASE_URL=http://localhost:11434

# Optional: If you ever switch to OpenAI
# OPENAI_API_KEY=sk-...

# Optional: LangSmith tracing (useful for debugging agent traces)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=promptshield

# Optional: Tavily web search (free tier available)
# TAVILY_API_KEY=tvly-...

# App settings
PROMPTSHIELD_ENV=development   # development | production
LOG_LEVEL=INFO
